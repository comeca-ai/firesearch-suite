# Firesearch Local Configuration
# Copy this file to .env.local and adjust as needed

# Internal service URLs (Docker network communication)
FIRECRAWL_API_URL=http://firecrawl:8001
CLAUDE_API_URL=http://claude-code-api:8000

# API Keys for local development (these are safe defaults for local use)
FIRECRAWL_API_KEY=fc-local-key
CLAUDE_API_KEY=sk-ant-local-key

# Next.js Configuration
NODE_ENV=production
PORT=3000

# Disable external API calls to ensure everything runs locally
DISABLE_EXTERNAL_APIs=true